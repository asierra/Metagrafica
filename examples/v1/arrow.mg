% flecha no rellena hacia abajo
OPST arrow
WW 0 2 0 3
PL 1 0  1.2 1  1.5 2  2 3  1 2  0 3  .5 2  .8 1  1 0 }
CLST

% Flechas blancas con punta en 0 0
% hacia abajo, arriba, derecha e izquierda

OPST arrowd
PL 0 0 .2 1 .5 2 1 3 0 2 -1 3 -.5 2 -.2 1 0 0 }
CLST

OPST arrowu
PL 0 0 .2 -1 .5 -2 1 -3 0 -2 -1 -3 -.5 -2 -.2 -1 0 0 }
CLST

OPST arrowl
PL 0 0 1 .2 2 .5 3 1 2 0 3 -1 2 -.5 1 -.2 0 0 }
CLST
 
OPST arrowr
PL 0 0 -1 .2 -2 .5 -3 1 -2 0 -3 -1 -2 -.5 -1 -.2 0 0 }
CLST
