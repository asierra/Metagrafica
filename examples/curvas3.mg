% Curvas de difracción para fig4-1 — traducción V3 de examples/v1/curvas3.mg.
% Puntos copiados VERBATIM del V1 (mismas coordenadas, misma world_window).
% PWST → fit(stretch=true); el reflejo del V1 (esquinas invertidas) se conserva
% (§10.2: fit honra el orden de las esquinas).

% y(t) = (sin(π·t)/t)²  — patrón de UNA rendija, muestreado 0 ≤ t ≤ 2
struct SenDeriv2() {
    world_window 0 2 0 9.87
    polyline {
        0 9.87        0.05 9.7886967  0.10 9.5491503  0.15 9.1603277
        0.20 8.6372876  0.25 8.000    0.30 7.2723166  0.35 6.4807561
        0.40 5.6531781  0.45 4.8174235  0.50 4.000    0.55 3.2248868
        0.60 2.5125236  0.65 1.8790358  0.70 1.3357316  0.75 0.88888889
        0.80 0.53983047  0.85 0.28526972  0.90 0.11789074  0.95 0.027115503
        1.00 0          1.05 0.022196591  1.10 0.078918597  1.15 0.15584679
        1.20 0.23992465  1.25 0.3200    1.30 0.38728313  1.35 0.43560638
        1.40 0.46148393  1.45 0.46398490  1.50 0.44444444  1.55 0.40604714
        1.60 0.35332363  1.65 0.29160427  1.70 0.22647353  1.75 0.16326531
        1.80 0.10663318  1.85 0.060221293  1.90 0.026451940  1.95 0.0064356981
        2.00 0
    }
}

