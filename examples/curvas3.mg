% Patrón simétrico: media curva dibujada dos veces, reflejada en x (esquinas
% invertidas en la mitad izquierda). V1 SNDVTSQ / SNCSDVTSQ.
struct SenDeriv2Sym() {
    fit(SenDeriv2, stretch=true) { 0.5 0  0 1 }   % mitad izquierda (reflejada en x)
    fit(SenDeriv2, stretch=true) { 0.5 0  1 1 }   % mitad derecha
}

struct SenCosDeriv2Sym() {
    fit(SenCosDeriv2, stretch=true) { 0.5 0  0 1 }
    fit(SenCosDeriv2, stretch=true) { 0.5 0  1 1 }
}
