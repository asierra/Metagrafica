% flecha rellena hacia abajo

% Flechas negras con punta en 0 0
% hacia abajo, arriba derecha e izquierda

OPST arrownd
PG 0 0 .2 1 .5 2 1 3 0 2 -1 3 -.5 2 -.2 1 0 0 }
CLST

OPST arrownu
PG 0 0 .2 -1 .5 -2 1 -3 0 -2 -1 -3 -.5 -2 -.2 -1 0 0 }
CLST

OPST arrownl
PG 0 0 1 .2 2 .5 3 1 2 0 3 -1 2 -.5 1 -.2 0 0 }
CLST
 
OPST arrownr
PG 0 0 -1 .2 -2 .5 -3 1 -2 0 -3 -1 -2 -.5 -1 -.2 0 0 }
CLST
