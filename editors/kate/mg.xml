<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE language SYSTEM "language.dtd">
<!--
  Resaltado de sintaxis MetaGráfica (V3) para Kate / KWrite / KDevelop.

  Instalación:
      mkdir -p ~/.local/share/org.kde.syntax-highlighting/syntax
      cp mg.xml ~/.local/share/org.kde.syntax-highlighting/syntax/
  Reiniciar Kate.  Aparece como "MetaGráfica" en la categoría Markup/Otros.

  A diferencia del de Geany, este resaltador SÍ distingue los argumentos
  nombrados (`color=`, `stretch=`) del resto, y colorea el markup del texto
  matemático (§14) dentro de las cadenas.
-->
<language name="MetaGrafica" section="Other" version="1" kateversion="5.0"
          extensions="*.mg" mimetype="text/x-metagrafica"
          author="Proyecto MetaGráfica" license="MIT"
          indenter="cstyle">

  <highlighting>

    <!-- Control de flujo, declaraciones, inclusión y configuración -->
    <list name="control">
      <item>struct</item>
      <item>for</item>
      <item>to</item>
      <item>step</item>
      <item>if</item>
      <item>else</item>
      <item>and</item>
      <item>or</item>
      <item>not</item>
      <item>include</item>
      <item>path</item>
      <item>display_size</item>
      <item>world_window</item>
    </list>

    <!-- Sentencias de estado (§7.3) y transformaciones locales (§11.1) -->
    <list name="estado">
      <item>color</item>
      <item>fill</item>
      <item>outlinefill</item>
      <item>hatch</item>
      <item>hatch_gap</item>
      <item>line_width</item>
      <item>dash</item>
      <item>font</item>
      <item>font_size</item>
      <item>align</item>
      <item>valign</item>
      <item>marker_size</item>
      <item>transform</item>
      <item>translate</item>
      <item>rotate</item>
      <item>scale</item>
      <item>shear</item>
    </list>

    <!-- Primitivas gráficas (§4) -->
    <list name="primitivas">
      <item>polyline</item>
      <item>polygon</item>
      <item>circle</item>
      <item>rectangle</item>
      <item>arc</item>
      <item>ellipse</item>
      <item>bezier</item>
      <item>dot</item>
      <item>marker</item>
      <item>polybar</item>
      <item>text</item>
      <item>sine</item>
      <item>compound</item>
    </list>

    <!-- Generadores y ejes (§13); placements (§10, §17) -->
    <list name="generadores">
      <item>ticks</item>
      <item>numbers</item>
      <item>axis</item>
      <item>grid</item>
      <item>plot</item>
      <item>xaxis</item>
      <item>yaxis</item>
      <item>legend</item>
      <item>entry</item>
      <item>place</item>
      <item>fit</item>
      <item>repeat</item>
    </list>

    <!-- Álgebra de paths (§9) y funciones escalares (§5.2) -->
    <list name="funciones">
      <item>transpose</item>
      <item>flip_x</item>
      <item>flip_y</item>
      <item>reverse</item>
      <item>concat</item>
      <item>smooth</item>
      <item>path_width</item>
      <item>path_x_min_at_y</item>
      <item>path_x_max_at_y</item>
      <item>path_x_bounds_at_y</item>
      <item>sin</item>
      <item>cos</item>
      <item>tan</item>
      <item>atan2</item>
      <item>sqrt</item>
      <item>abs</item>
      <item>mod</item>
      <item>exp</item>
      <item>ln</item>
      <item>str</item>
      <item>len</item>
      <item>gray</item>
    </list>

    <list name="constantes">
      <item>pi</item>
      <item>true</item>
      <item>false</item>
    </list>

    <contexts>

      <context name="Normal" attribute="Normal" lineEndContext="#stay">
        <DetectSpaces/>
        <!-- Comentario estilo TeX hasta fin de línea (§1) -->
        <DetectChar attribute="Comentario" context="Comentario" char="%"/>
        <DetectChar attribute="Cadena" context="Cadena" char="&quot;"/>

        <!-- Argumento nombrado: identificador seguido de '=' pero no de '=='.
             Se resalta el nombre; el '=' lo toma la regla de operadores. -->
        <RegExpr attribute="Argumento" context="#stay"
                 String="\b[a-zA-Z_][a-zA-Z_0-9]*(?=\s*=[^=])"/>

        <!-- Referencia a path: &nombre (§9) -->
        <RegExpr attribute="RefPath" context="#stay"
                 String="&amp;[a-zA-Z_][a-zA-Z_0-9]*"/>

        <keyword attribute="Control"     context="#stay" String="control"/>
        <keyword attribute="Estado"      context="#stay" String="estado"/>
        <keyword attribute="Primitiva"   context="#stay" String="primitivas"/>
        <keyword attribute="Generador"   context="#stay" String="generadores"/>
        <keyword attribute="Funcion"     context="#stay" String="funciones"/>
        <keyword attribute="Constante"   context="#stay" String="constantes"/>

        <!-- Nombre de struct en su definición -->
        <RegExpr attribute="Struct" context="#stay"
                 String="(?&lt;=\bstruct\s)\s*[a-zA-Z_][a-zA-Z_0-9]*"/>

        <!-- Números: enteros, decimales sin cero inicial y notación científica.
             Sin signo: el '-' unario es del parser (§1). -->
        <RegExpr attribute="Numero" context="#stay"
                 String="\b[0-9]*\.?[0-9]+([eE][-+]?[0-9]+)?\b"/>
        <RegExpr attribute="Numero" context="#stay"
                 String="\.[0-9]+([eE][-+]?[0-9]+)?"/>

        <AnyChar attribute="Operador" context="#stay" String="+-*/^&lt;&gt;=!&amp;,;"/>
        <AnyChar attribute="Delimitador" context="#stay" String="(){}[]"/>
      </context>

      <context name="Comentario" attribute="Comentario" lineEndContext="#pop">
        <DetectSpaces/>
        <IncludeRules context="##Alerts"/>
        <DetectIdentifier/>
      </context>

      <!-- Las cadenas no admiten escapes: STRING = \"[^\"]*\" en el lexer.
           No cierran en fin de línea, igual que el lexer. -->
      <context name="Cadena" attribute="Cadena" lineEndContext="#stay">
        <DetectChar attribute="Cadena" context="#pop" char="&quot;"/>
        <!-- Modo matemático $…$ (§14.1) -->
        <DetectChar attribute="Math" context="Math" char="$"/>
        <!-- Cambio de fuente en línea: /b /i /r … -->
        <RegExpr attribute="Markup" context="#stay" String="/[a-zA-Z]"/>
      </context>

      <context name="Math" attribute="Math" lineEndContext="#stay">
        <DetectChar attribute="Math" context="#pop" char="$"/>
        <DetectChar attribute="Cadena" context="#pop#pop" char="&quot;"/>
        <!-- Comando TeX: \alpha, \mu … (cualquier no alfabético lo cierra) -->
        <RegExpr attribute="Simbolo" context="#stay" String="\\[a-zA-Z]+"/>
        <AnyChar attribute="Markup" context="#stay" String="_^{}"/>
        <RegExpr attribute="Markup" context="#stay" String="/[a-zA-Z]"/>
      </context>

    </contexts>

    <itemDatas>
      <itemData name="Normal"       defStyleNum="dsNormal"/>
      <itemData name="Control"      defStyleNum="dsKeyword"/>
      <itemData name="Estado"       defStyleNum="dsBuiltIn"/>
      <itemData name="Primitiva"    defStyleNum="dsFunction"/>
      <itemData name="Generador"    defStyleNum="dsFunction" bold="1"/>
      <itemData name="Funcion"      defStyleNum="dsBuiltIn"/>
      <itemData name="Constante"    defStyleNum="dsConstant"/>
      <itemData name="Struct"       defStyleNum="dsDataType"/>
      <itemData name="Argumento"    defStyleNum="dsAttribute"/>
      <itemData name="RefPath"      defStyleNum="dsVariable"/>
      <itemData name="Numero"       defStyleNum="dsDecVal"/>
      <itemData name="Cadena"       defStyleNum="dsString"/>
      <itemData name="Math"         defStyleNum="dsSpecialString"/>
      <itemData name="Simbolo"      defStyleNum="dsSpecialChar"/>
      <itemData name="Markup"       defStyleNum="dsSpecialChar"/>
      <itemData name="Comentario"   defStyleNum="dsComment"/>
      <itemData name="Operador"     defStyleNum="dsOperator"/>
      <itemData name="Delimitador"  defStyleNum="dsNormal"/>
    </itemDatas>

  </highlighting>

  <general>
    <comments>
      <comment name="singleLine" start="%" position="afterwhitespace"/>
    </comments>
    <keywords casesensitive="1" additionalDeliminator="&amp;"/>
  </general>

</language>
